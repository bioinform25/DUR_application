rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 각자 자기 자신의 users/{내uid} 문서만 읽고 쓸 수 있다
    // (내가 속한 그룹 목록 + 그룹별 개인 닉네임 저장용)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // families/{6자리코드} 문서: members는 { uid: { role: 'editor'|'viewer', displayName } } 맵.
    // - 조회(get)는 로그인만 하면 가능(참여 전 코드 존재 확인용).
    // - 생성 시에는 만든 사람 자신을 editor로 등록해야 한다.
    // - 수정은 아래 네 가지 경우만 허용한다:
    //   1) 아직 멤버가 아닌 사람이 자기 자신을 viewer로만 추가(참여) - editor 셀프 승격 방지
    //   2) 이미 editor인 멤버 - 바구니/알림/멤버 역할변경/추방/복용체크 등 전부 허용
    //   3) 이미 viewer인 멤버 - members에서 자기 자신을 빼는 것(그룹 나가기)만 허용
    //   4) 이미 viewer인 멤버 - takenDoses(자기 복용 체크)만 갱신하는 것은 허용
    //      (바구니·알림 구성 자체는 못 건드리지만, "내가 먹었다"는 표시는 보기전용도 할 수 있어야 함)
    match /families/{familyId} {
      allow get: if request.auth != null;

      allow create: if request.auth != null &&
        request.resource.data.members[request.auth.uid].role == 'editor';

      allow update: if request.auth != null && (
        (
          !(request.auth.uid in resource.data.members) &&
          request.resource.data.members[request.auth.uid].role == 'viewer' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
        ) ||
        (
          request.auth.uid in resource.data.members &&
          resource.data.members[request.auth.uid].role == 'editor'
        ) ||
        (
          request.auth.uid in resource.data.members &&
          resource.data.members[request.auth.uid].role == 'viewer' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
          !(request.auth.uid in request.resource.data.members)
        ) ||
        (
          request.auth.uid in resource.data.members &&
          resource.data.members[request.auth.uid].role == 'viewer' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['takenDoses'])
        )
      );
    }
  }
}
